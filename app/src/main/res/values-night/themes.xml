<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Noxgroup" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Palette de couleurs vifs pour les accents -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/surface_lighter</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/surface_dark</item>
        <item name="colorOnSecondaryContainer">@color/secondary</item>

        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/black</item>
        <item name="colorTertiaryContainer">@color/tertiary</item>
        <item name="colorOnTertiaryContainer">@color/black</item>

        <!-- Thème sombre profond (Gris foncé vers Noir) -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_title</item>
        <item name="colorSurfaceVariant">@color/surface_lighter</item>
        <item name="colorOnSurfaceVariant">@color/text_body</item>

        <!-- Barres système forcées à la couleur du thème -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>

        <!-- Icônes blanches sur fond sombre -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Désactive le contraste forcé (le voile blanc/gris) sur Android 10+ -->
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
    </style>
</resources>